# --- 1. ENVIRONMENT & DEPENDENCIES ---
venv/
.venv/
env/
bin/
lib/
include/
# Ignore Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# --- 2. DATA & SECURITY (CRITICAL) ---
# Ignore the actual database files
finance.db
*.db
# Ignore SQLite temporary/journal files
*.db-journal
*.db-shm
*.db-wal
# Ignore your secret credentials
.streamlit/secrets.toml

# --- 3. IDE & SYSTEM FILES ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- 4. LOGS & EXPORTS ---
*.log
exports/
reports/*.pdf
reports/*.csv